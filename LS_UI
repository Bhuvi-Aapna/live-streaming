const ITEMS_PER_PAGE = 25;
const MAX_RETRY_ATTEMPTS = 8;
const RETRY_DELAY = 5000;

const SERVER = import.meta.env.VITE_APP_LIVE_STREAM_URL;

// Add StreamData interface
interface StreamData {
  id: string;
  producerId: string;
  stream: MediaStream;
  hasVideo: boolean;
  hasAudio: boolean;
  kind: string;
}

interface JoinRoomResponse {
  error?: string;
  rtpCapabilities?: any;
}

interface TransportResponse {
  error?: string;
  id: string;
  iceParameters: any;
  iceCandidates: any;
  dtlsParameters: any;
}

interface ConnectResponse {
  error?: string;
}

interface ConsumeResponse {
  error?: string;
  consumers?: Array<{
    id: string;
    producerId: string;
    kind: string;
    rtpParameters: any;
  }>;
}

const LiveStreaming: React.FC = () => {
  const dispatch = useDispatch();
  const SelectedUser: any = useSelector<RootState>(
